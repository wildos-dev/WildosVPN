{
  "id": "vless_grpc_tls",
  "name": "VLESS gRPC + TLS",
  "description": "VLESS через gRPC с TLS и автоматическим мультиплексированием",
  "protocol": "vless",
  "transport": "grpc",
  "security": "tls",
  "category": "vless",
  "complexity": "advanced",
  "cdn_support": true,
  "multiplexing": true,
  "default_port": 443,
  "tags": ["grpc", "vless", "tls", "performance", "h2", "auto-mux"],
  "icon": "⚡",
  "base_config": {
    "protocol": "vless",
    "settings": {
      "clients": [
        {
          "id": "",
          "level": 0
        }
      ],
      "decryption": "none"
    },
    "streamSettings": {
      "network": "grpc",
      "security": "tls",
      "grpcSettings": {
        "serviceName": "VlessService",
        "multiMode": true
      },
      "tlsSettings": {
        "serverName": "example.com",
        "alpn": ["h2"],
        "certificates": [
          {
            "certificateFile": "/path/to/certificate.crt",
            "keyFile": "/path/to/private.key"
          }
        ]
      }
    },
    "sniffing": {
      "enabled": true,
      "destOverride": ["http", "tls"]
    }
  },
  "required_fields": [
    "tag", 
    "port", 
    "streamSettings.grpcSettings.serviceName",
    "streamSettings.tlsSettings.serverName",
    "streamSettings.tlsSettings.certificates.0.certificateFile",
    "streamSettings.tlsSettings.certificates.0.keyFile"
  ],
  "auto_gen_fields": ["clients.0.id"],
  "editable_fields": [
    "clients.0.level",
    "streamSettings.grpcSettings.serviceName",
    "streamSettings.grpcSettings.multiMode",
    "streamSettings.tlsSettings.serverName",
    "streamSettings.tlsSettings.certificates.0.certificateFile",
    "streamSettings.tlsSettings.certificates.0.keyFile",
    "sniffing.enabled",
    "sniffing.destOverride"
  ],
  "advanced_fields": [
    "streamSettings.tlsSettings.alpn",
    "streamSettings.tlsSettings.allowInsecure",
    "streamSettings.grpcSettings.authority",
    "streamSettings.sockopt"
  ],
  "field_descriptions": {
    "clients.0.level": "Уровень пользователя (0-255)",
    "streamSettings.grpcSettings.serviceName": "Имя gRPC сервиса (например: VlessService, ApiService)",
    "streamSettings.grpcSettings.multiMode": "Множественные потоки (рекомендуется true для VLESS)",
    "streamSettings.tlsSettings.serverName": "Доменное имя для TLS",
    "streamSettings.tlsSettings.certificates.0.certificateFile": "Путь к SSL сертификату",
    "streamSettings.tlsSettings.certificates.0.keyFile": "Путь к приватному ключу"
  },
  "restrictions": [
    "Требует HTTP/2 поддержку",
    "Требует валидный SSL сертификат",
    "serviceName должен быть уникальным",
    "flow параметр НЕ поддерживается с gRPC",
    "Автоматическое мультиплексирование повышает производительность"
  ],
  "grpc_config": {
    "recommended_service_names": ["VlessService", "TunService", "GunService", "ApiService"],
    "http2_required": true,
    "alpn_required": ["h2"],
    "multimode_recommended": true
  }
}
{
  "id": "vless_grpc_reality",
  "name": "VLESS gRPC + Reality",
  "description": "VLESS через gRPC с Reality для максимальной безопасности",
  "protocol": "vless",
  "transport": "grpc",
  "security": "reality",
  "category": "grpc",
  "complexity": "advanced",
  "cdn_support": false,
  "multiplexing": true,
  "default_port": 443,
  "tags": ["grpc", "vless", "reality", "stealth", "security", "h2"],
  "icon": "⚡",
  "base_config": {
    "protocol": "vless",
    "settings": {
      "clients": [
        {
          "id": "",
          "level": 0,
          "flow": ""
        }
      ],
      "decryption": "none"
    },
    "streamSettings": {
      "network": "grpc",
      "security": "reality",
      "grpcSettings": {
        "serviceName": "TunService",
        "multiMode": true
      },
      "realitySettings": {
        "show": false,
        "dest": "www.microsoft.com:443",
        "xver": 0,
        "serverNames": ["www.microsoft.com"],
        "privateKey": "",
        "shortIds": [""]
      }
    },
    "sniffing": {
      "enabled": true,
      "destOverride": ["http", "tls"]
    }
  },
  "required_fields": [
    "tag", 
    "port", 
    "streamSettings.grpcSettings.serviceName",
    "streamSettings.realitySettings.dest",
    "streamSettings.realitySettings.serverNames.0"
  ],
  "auto_gen_fields": [
    "clients.0.id",
    "streamSettings.realitySettings.privateKey",
    "streamSettings.realitySettings.shortIds.0"
  ],
  "editable_fields": [
    "clients.0.level",
    "clients.0.flow",
    "streamSettings.grpcSettings.serviceName",
    "streamSettings.grpcSettings.multiMode",
    "streamSettings.realitySettings.dest",
    "streamSettings.realitySettings.serverNames.0",
    "streamSettings.realitySettings.show",
    "sniffing.enabled",
    "sniffing.destOverride"
  ],
  "advanced_fields": [
    "streamSettings.realitySettings.xver",
    "streamSettings.realitySettings.privateKey",
    "streamSettings.realitySettings.shortIds",
    "streamSettings.grpcSettings.authority",
    "streamSettings.sockopt"
  ],
  "field_descriptions": {
    "clients.0.level": "Уровень пользователя (0-255)",
    "clients.0.flow": "XTLS flow (оставьте пустым для gRPC)",
    "streamSettings.grpcSettings.serviceName": "Имя gRPC сервиса",
    "streamSettings.realitySettings.dest": "Целевой сайт для маскировки (например: www.microsoft.com:443)",
    "streamSettings.realitySettings.serverNames.0": "SNI имя (должно совпадать с dest)",
    "streamSettings.realitySettings.show": "Отображать отладочную информацию",
    "streamSettings.realitySettings.privateKey": "Приватный ключ Reality (автогенерируется)",
    "streamSettings.realitySettings.shortIds.0": "Короткий ID (автогенерируется)"
  },
  "restrictions": [
    "Требует HTTP/2 поддержку",
    "НЕ требует SSL сертификат (Reality создает свой)",
    "Dest сайт должен поддерживать TLS 1.3",
    "ServerNames должен совпадать с dest",
    "flow должен быть пустым для gRPC",
    "Не работает с обычными CDN"
  ],
  "reality_config": {
    "recommended_destinations": [
      "www.microsoft.com:443",
      "www.cloudflare.com:443", 
      "www.bing.com:443",
      "www.yahoo.com:443"
    ],
    "grpc_service_names": ["TunService", "GunService", "VlessService"],
    "tls13_required": true
  }
}
{
  "id": "vless_splithttp_tls",
  "name": "VLESS SplitHTTP + TLS",
  "description": "VLESS SplitHTTP с TLS - максимальный обход блокировок DPI",
  "protocol": "vless",
  "transport": "splithttp",
  "security": "tls",
  "category": "vless",
  "complexity": "medium",
  "cdn_support": true,
  "multiplexing": true,
  "default_port": 443,
  "tags": ["splithttp", "vless", "tls", "modern", "bypass", "dpi-evasion"],
  "icon": "⚡",
  "base_config": {
    "protocol": "vless",
    "settings": {
      "clients": [
        {
          "id": "",
          "level": 0,
          "flow": ""
        }
      ],
      "decryption": "none"
    },
    "streamSettings": {
      "network": "splithttp",
      "security": "tls",
      "splithttpSettings": {
        "path": "/api/data",
        "host": "example.com",
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
          "Content-Type": "application/json"
        },
        "scMaxConcurrentPosts": 8,
        "scMaxEachPostBytes": "800000",
        "scMinPostsIntervalMs": 50
      },
      "tlsSettings": {
        "serverName": "example.com",
        "alpn": ["h2", "http/1.1"],
        "certificates": [
          {
            "certificateFile": "/path/to/certificate.crt",
            "keyFile": "/path/to/private.key"
          }
        ]
      }
    },
    "sniffing": {
      "enabled": true,
      "destOverride": ["http", "tls"]
    }
  },
  "required_fields": [
    "tag", 
    "port", 
    "streamSettings.splithttpSettings.path",
    "streamSettings.splithttpSettings.host",
    "streamSettings.tlsSettings.serverName",
    "streamSettings.tlsSettings.certificates.0.certificateFile",
    "streamSettings.tlsSettings.certificates.0.keyFile"
  ],
  "auto_gen_fields": ["clients.0.id"],
  "editable_fields": [
    "clients.0.level",
    "clients.0.flow",
    "streamSettings.splithttpSettings.path",
    "streamSettings.splithttpSettings.host",
    "streamSettings.splithttpSettings.headers.User-Agent",
    "streamSettings.splithttpSettings.headers.Content-Type",
    "streamSettings.splithttpSettings.scMaxConcurrentPosts",
    "streamSettings.splithttpSettings.scMaxEachPostBytes",
    "streamSettings.splithttpSettings.scMinPostsIntervalMs",
    "streamSettings.tlsSettings.serverName",
    "streamSettings.tlsSettings.certificates.0.certificateFile",
    "streamSettings.tlsSettings.certificates.0.keyFile",
    "sniffing.enabled",
    "sniffing.destOverride"
  ],
  "advanced_fields": [
    "streamSettings.tlsSettings.alpn",
    "streamSettings.tlsSettings.allowInsecure",
    "streamSettings.splithttpSettings.headers",
    "streamSettings.sockopt"
  ],
  "field_descriptions": {
    "clients.0.level": "Уровень пользователя (0-255)",
    "clients.0.flow": "XTLS flow (оставьте пустым для SplitHTTP)",
    "streamSettings.splithttpSettings.path": "HTTP путь для SplitHTTP (например: /api/data, /upload)",
    "streamSettings.splithttpSettings.host": "Host заголовок",
    "streamSettings.splithttpSettings.headers.User-Agent": "User-Agent для маскировки под браузер",
    "streamSettings.splithttpSettings.headers.Content-Type": "Content-Type для POST запросов",
    "streamSettings.splithttpSettings.scMaxConcurrentPosts": "Максимальное количество одновременных POST запросов",
    "streamSettings.splithttpSettings.scMaxEachPostBytes": "Максимальный размер каждого POST запроса в байтах",
    "streamSettings.splithttpSettings.scMinPostsIntervalMs": "Минимальный интервал между POST запросами (мс)",
    "streamSettings.tlsSettings.serverName": "Доменное имя для TLS",
    "streamSettings.tlsSettings.certificates.0.certificateFile": "Путь к SSL сертификату",
    "streamSettings.tlsSettings.certificates.0.keyFile": "Путь к приватному ключу"
  },
  "restrictions": [
    "Требует новейшую версию Xray (1.8.1+)",
    "flow должен быть пустым для SplitHTTP",
    "Расщепляет трафик на множество HTTP запросов",
    "Максимальная эффективность против DPI",
    "Имитирует API-вызовы и загрузку данных",
    "Отличная совместимость с CDN"
  ],
  "splithttp_config": {
    "recommended_paths": ["/api/data", "/upload", "/stream", "/sync"],
    "optimal_concurrent_posts": 8,
    "optimal_post_size": "800000",
    "optimal_interval_ms": 50,
    "dpi_evasion_optimized": true,
    "api_simulation": true
  }
}
{
  "id": "trojan_tls_basic",
  "name": "Trojan TLS Basic",
  "description": "Базовая конфигурация Trojan с TLS шифрованием",
  "protocol": "trojan",
  "transport": "tcp",
  "security": "tls",
  "category": "basic",
  "complexity": "medium",
  "cdn_support": false,
  "multiplexing": true,
  "default_port": 443,
  "tags": ["basic", "trojan", "tls", "secure"],
  "icon": "🔒",
  "base_config": {
    "protocol": "trojan",
    "settings": {
      "clients": [
        {
          "password": "",
          "level": 0
        }
      ]
    },
    "streamSettings": {
      "network": "tcp",
      "security": "tls",
      "tlsSettings": {
        "serverName": "example.com",
        "certificates": [
          {
            "certificateFile": "/path/to/certificate.crt",
            "keyFile": "/path/to/private.key"
          }
        ]
      }
    },
    "sniffing": {
      "enabled": true,
      "destOverride": ["http", "tls"]
    }
  },
  "required_fields": [
    "tag", 
    "port", 
    "streamSettings.tlsSettings.serverName",
    "streamSettings.tlsSettings.certificates.0.certificateFile",
    "streamSettings.tlsSettings.certificates.0.keyFile"
  ],
  "auto_gen_fields": ["clients.0.password"],
  "editable_fields": [
    "clients.0.level",
    "streamSettings.tlsSettings.serverName",
    "streamSettings.tlsSettings.certificates.0.certificateFile",
    "streamSettings.tlsSettings.certificates.0.keyFile",
    "sniffing.enabled",
    "sniffing.destOverride"
  ],
  "advanced_fields": [
    "streamSettings.tlsSettings.alpn",
    "streamSettings.tlsSettings.allowInsecure",
    "streamSettings.sockopt"
  ],
  "field_descriptions": {
    "clients.0.level": "Уровень пользователя (0-255)",
    "clients.0.password": "Пароль для подключения",
    "streamSettings.tlsSettings.serverName": "Доменное имя для TLS",
    "streamSettings.tlsSettings.certificates.0.certificateFile": "Путь к SSL сертификату",
    "streamSettings.tlsSettings.certificates.0.keyFile": "Путь к приватному ключу"
  },
  "restrictions": [
    "Требует валидный SSL сертификат",
    "Домен должен указывать на сервер",
    "Рекомендуется использовать порт 443"
  ]
}
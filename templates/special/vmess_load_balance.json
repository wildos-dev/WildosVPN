{
  "id": "vmess_load_balance",
  "name": "VMess Load Balance",
  "description": "VMess с балансировкой нагрузки между несколькими исходящими соединениями",
  "protocol": "vmess",
  "transport": "tcp",
  "security": "tls",
  "category": "vmess",
  "complexity": "advanced",
  "cdn_support": false,
  "multiplexing": true,
  "default_port": 443,
  "tags": ["load-balance", "vmess", "performance", "routing", "special"],
  "icon": "📡",
  "base_config": {
    "protocol": "vmess",
    "settings": {
      "clients": [
        {
          "id": "",
          "level": 0,
          "alterId": 0
        }
      ]
    },
    "streamSettings": {
      "network": "tcp",
      "security": "tls",
      "tlsSettings": {
        "serverName": "example.com",
        "certificates": [
          {
            "certificateFile": "/path/to/certificate.crt",
            "keyFile": "/path/to/private.key"
          }
        ]
      },
      "sockopt": {
        "tcpKeepAliveInterval": 30,
        "mark": 255
      }
    },
    "routing": {
      "domainStrategy": "IPIfNonMatch",
      "balancers": [
        {
          "tag": "load-balancer",
          "selector": ["outbound-1", "outbound-2", "outbound-3"],
          "strategy": {
            "type": "leastPing"
          }
        }
      ],
      "rules": [
        {
          "balancerTag": "load-balancer",
          "type": "field",
          "network": "tcp,udp"
        }
      ]
    },
    "sniffing": {
      "enabled": true,
      "destOverride": ["http", "tls"]
    }
  },
  "required_fields": [
    "tag", 
    "port", 
    "streamSettings.tlsSettings.serverName",
    "streamSettings.tlsSettings.certificates.0.certificateFile",
    "streamSettings.tlsSettings.certificates.0.keyFile"
  ],
  "auto_gen_fields": ["clients.0.id"],
  "editable_fields": [
    "clients.0.level",
    "clients.0.alterId",
    "streamSettings.tlsSettings.serverName",
    "streamSettings.tlsSettings.certificates.0.certificateFile",
    "streamSettings.tlsSettings.certificates.0.keyFile",
    "routing.balancers.0.selector",
    "routing.balancers.0.strategy.type",
    "routing.domainStrategy",
    "streamSettings.sockopt.tcpKeepAliveInterval",
    "sniffing.enabled",
    "sniffing.destOverride"
  ],
  "advanced_fields": [
    "routing.balancers",
    "routing.rules",
    "streamSettings.sockopt.mark",
    "streamSettings.sockopt.tcpFastOpen"
  ],
  "field_descriptions": {
    "clients.0.level": "Уровень пользователя (0-255)",
    "clients.0.alterId": "Дополнительный ID (рекомендуется 0)",
    "streamSettings.tlsSettings.serverName": "Доменное имя для TLS",
    "streamSettings.tlsSettings.certificates.0.certificateFile": "Путь к SSL сертификату",
    "streamSettings.tlsSettings.certificates.0.keyFile": "Путь к приватному ключу",
    "routing.balancers.0.selector": "Список тегов исходящих соединений для балансировки",
    "routing.balancers.0.strategy.type": "Стратегия балансировки (leastPing, random, roundRobin)",
    "routing.domainStrategy": "Стратегия разрешения доменов",
    "streamSettings.sockopt.tcpKeepAliveInterval": "Интервал TCP Keep-Alive (секунды)"
  },
  "load_balance_strategies": [
    "leastPing",
    "random", 
    "roundRobin",
    "leastLoad"
  ],
  "restrictions": [
    "Требует настройку нескольких исходящих соединений",
    "Автоматически распределяет нагрузку между серверами",
    "leastPing выбирает сервер с наименьшим пингом",
    "Повышает отказоустойчивость системы",
    "Оптимизирует производительность сети"
  ],
  "load_balance_config": {
    "recommended_outbounds": ["outbound-1", "outbound-2", "outbound-3"],
    "optimal_strategy": "leastPing",
    "domain_strategy": "IPIfNonMatch",
    "performance_mode": "high_availability"
  }
}